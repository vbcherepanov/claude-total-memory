# total-agent-memory — example environment configuration
#
# Copy to .env and edit. All values shown are defaults; uncommenting them
# is harmless. The full reference is in README.md > Configuration.

# -----------------------------------------------------------------------------
# v11.0 — Memory Mode (fast = production default, zero LLM in hot path)
# -----------------------------------------------------------------------------

MEMORY_MODE=fast
MEMORY_USE_LLM_IN_HOT_PATH=false
MEMORY_ALLOW_OLLAMA_IN_HOT_PATH=false
MEMORY_RERANK_ENABLED=false
MEMORY_ENRICHMENT_ENABLED=false

# Per-space embedding models (empty -> fall back to TEXT model, but
# the row still records its space -- future model swap is config-only)
MEMORY_TEXT_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MEMORY_CODE_EMBED_MODEL=
MEMORY_LOG_EMBED_MODEL=
MEMORY_CONFIG_EMBED_MODEL=
MEMORY_DEFAULT_EMBEDDING_SPACE=text

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# MEMORY_DB=~/.claude-memory/memory.db
# DASHBOARD_PORT=37737
# MEMORY_MCP_PORT=3737

# -----------------------------------------------------------------------------
# v10.5 -- LLM enrichment (only consulted when MEMORY_USE_LLM_IN_HOT_PATH=true
# or async worker is enabled via MEMORY_ENRICHMENT_ENABLED=true)
# -----------------------------------------------------------------------------

# MEMORY_LLM_ENABLED=auto
# MEMORY_LLM_MODEL=qwen2.5-coder:7b
# OLLAMA_URL=http://localhost:11434
# MEMORY_LLM_TIMEOUT_SEC=60
# MEMORY_TRIPLE_TIMEOUT_SEC=30
# MEMORY_ENRICH_TIMEOUT_SEC=45
# MEMORY_REPR_TIMEOUT_SEC=60

# -----------------------------------------------------------------------------
# v10.1 -- async enrichment worker (auto-enabled in balanced/deep modes)
# -----------------------------------------------------------------------------

# MEMORY_ASYNC_ENRICHMENT=true        # set automatically by MEMORY_MODE
# MEMORY_ENRICH_TICK_SEC=0.1
# MEMORY_ENRICH_BATCH=5
# MEMORY_ENRICH_MAX_ATTEMPTS=3
# MEMORY_ENRICH_STALE_AFTER_SEC=60

# -----------------------------------------------------------------------------
# Cloud LLM provider (optional -- replaces local Ollama in deep mode)
# -----------------------------------------------------------------------------

# MEMORY_LLM_PROVIDER=openai          # openai | anthropic | ollama
# MEMORY_LLM_API_KEY=
# MEMORY_LLM_API_BASE=                # e.g. https://openrouter.ai/api/v1
# MEMORY_LLM_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Cloud embedding provider (optional -- requires re-embed on dimension change)
# -----------------------------------------------------------------------------

# MEMORY_EMBED_PROVIDER=fastembed     # fastembed | sentence-transformers | ollama | openai | cohere
# MEMORY_EMBED_API_KEY=
# MEMORY_EMBED_MODEL=                 # e.g. text-embedding-3-small (1536d)
